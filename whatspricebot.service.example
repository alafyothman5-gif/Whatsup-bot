[Unit]
Description=WhatsPriceBot Flask Service
After=network.target

[Service]
WorkingDirectory=/opt/whatspricebot
EnvironmentFile=/opt/whatspricebot/.env
ExecStart=/opt/whatspricebot/venv/bin/gunicorn -w 2 -b 0.0.0.0:8090 app:app
Restart=always
RestartSec=5
User=root

[Install]
WantedBy=multi-user.target
